  "dependencies": [
    "vcrun2005", "vcrun2008", "vcrun2010", "vcrun2012", "vcrun2013", "vcrun2022",
    "d3dx9", "d3dcompiler_43", "d3dcompiler_47",
    "dotnet40", "dotnet48", "physx", "xact", "gdiplus", "dsound", "xna40", "openal"
